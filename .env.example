# SkillSpace Environment Configuration
# ═══════════════════════════════════════════════════════════════
# For Vercel deployment, add these as Environment Variables in:
# Vercel Dashboard → Your Project → Settings → Environment Variables
# ═══════════════════════════════════════════════════════════════

# ─── DATABASE (Required) ──────────────────────────────────────
# Get from: Neon Console → Your Project → Connection Details → Pooled connection
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-2.aws.neon.tech/skillspace?sslmode=require

# ─── AUTH (Required) ──────────────────────────────────────────
# Generate secret: run `openssl rand -base64 32` in terminal
BETTER_AUTH_SECRET=your-generated-secret-here
# Set to your Vercel deployment URL
BETTER_AUTH_URL=https://skillspace-registry.vercel.app
NEXT_PUBLIC_APP_URL=https://skillspace-registry.vercel.app

# ─── GITHUB OAuth (Optional — enables GitHub sign-in) ─────────
# Get from: GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Homepage URL: https://skillspace-registry.vercel.app
#   Callback URL: https://skillspace-registry.vercel.app/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── STORAGE (Optional — for .skillpkg file uploads) ──────────
# Get from: Cloudflare Dashboard → R2 → Manage R2 API Tokens
STORAGE_BUCKET=skillspace-packages
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# ─── CLI Model Providers (Optional — for local CLI usage) ─────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── Firewall (Optional) ──────────────────────────────────────
FIREWALL_ENABLED=true
FIREWALL_MODEL=ollama/llama3

# ─── MCP (Optional) ───────────────────────────────────────────
MCP_ALLOWED_TRANSPORTS=stdio,http
MCP_HTTP_ALLOWLIST=http://localhost:3001,http://localhost:3002
