# SkillSpace Environment Configuration

# --- Registry Server (apps/registry) ---
DATABASE_URL=postgresql://user:password@host:5432/skillspace
DIRECT_URL=postgresql://user:password@host:5432/skillspace
BETTER_AUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# GitHub OAuth (optional — for GitHub sign-in)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Storage (optional — for .skillpkg file uploads)
STORAGE_BUCKET=skillspace-packages
STORAGE_ENDPOINT=https://your-r2-endpoint
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# --- Model Providers (CLI ~/.skillspace/config.json or env vars) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# --- Firewall (runtime security scanning) ---
FIREWALL_ENABLED=true
FIREWALL_MODEL=ollama/llama3

# --- MCP ---
MCP_ALLOWED_TRANSPORTS=stdio,http
MCP_HTTP_ALLOWLIST=http://localhost:3001,http://localhost:3002
