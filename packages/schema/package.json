{
  "name": "@skillspace/schema",
  "version": "0.1.0",
  "private": true,
  "description": "Shared types and validators for SkillSpace",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "yaml": "^2.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
