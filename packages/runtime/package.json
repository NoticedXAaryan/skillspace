{
  "name": "@skillspace/runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SkillSpace Runtime — core execution engine",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsc -b --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@skillspace/schema": "workspace:*",
    "jexl": "^2.3.0",
    "semver": "^7.6.0",
    "tar": "^7.4.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/jexl": "^2.3.4",
    "@types/semver": "^7.5.0",
    "@types/tar": "^6.1.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
