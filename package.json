{
  "name": "skillspace",
  "version": "0.1.0",
  "private": true,
  "description": "The universal runtime and registry for AI capabilities",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml}\"",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.9.0",
    "prettier": "^3.3.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@11.5.0",
  "engines": {
    "node": ">=20.0.0"
  }
}
