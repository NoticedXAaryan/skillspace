{
  "name": "@air/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SkillSpace CLI — install, run, and publish AI capabilities",
  "bin": {
    "air": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "compile": "bun build ./src/index.ts --compile --outfile dist/air",
    "dev": "tsc -w",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@skillspace/runtime": "workspace:*",
    "@skillspace/schema": "workspace:*",
    "chalk": "^5.4.0",
    "cli-table3": "^0.6.0",
    "commander": "^13.1.0",
    "ignore": "^7.0.5",
    "inquirer": "^12.3.0",
    "node-fetch": "^3.3.0",
    "ora": "^8.1.0",
    "picocolors": "^1.1.1",
    "tar": "^7.4.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "rimraf": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6"
  }
}
